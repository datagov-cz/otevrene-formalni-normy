@prefix : <https://ofn.gov.cz/dobrovolné-svazky-obcí/2024-04-01/generator-configuration#>.
@prefix dsvgc: <https://dataspecer.com/work-in-progress/generator-configuration/>.
@prefix ce: <https://dataspecer.com/work-in-progress/generator-configuration/configuration-entry/>.
@prefix kv: <https://dataspecer.com/work-in-progress/generator-configuration/key-value/>.

<https://ofn.gov.cz/dobrovolné-svazky-obcí/2024-04-01/generator-configuration#> a dsvgc:configuration;
    dsvgc:has-configurations :data-specification, :json.
:data-specification a <https://dataspecer.com/work-in-progress/generator-configuration/configuration-entry/>;
    dsvgc:has-configuration-type ce:data-specification;
    kv:instancesHaveIdentity "\"OPTIONAL\"";
    kv:instancesSpecifyTypes "\"OPTIONAL\"";
    kv:publicBaseUrl "\"https://ofn.gov.cz/rejstřík-svazku-obcí/2026-04-01\"";
    kv:renameArtifacts "{\"http://example.com/generator/json-schema\":\"schémata/schéma.json\",\"http://dataspecer.com/generator/json-ld\":\"kontexty/kontext.jsonld\"}";
    kv:useGenerators "{\"xml\":false,\"csv\":false,\"sparql\":false,\"shacl\":false,\"shex\":false,\"openapi\":false,\"jsonExample\":false}".
:json a <https://dataspecer.com/work-in-progress/generator-configuration/configuration-entry/>;
    dsvgc:has-configuration-type ce:json;
    kv:jsonIdKeyAlias "\"iri\"";
    kv:jsonTypeKeyAlias "\"typ\"".
