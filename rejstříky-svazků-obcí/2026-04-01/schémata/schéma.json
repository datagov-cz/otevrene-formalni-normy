        "type": "object",
        "required": [
          "iri",
          "typ",
          "ičo",
          "název",
          "datum_vzniku",
          "předmět_činnosti",
          "zdroj_výčtu_členů",
          "má_členskou_obec"
        ],
        "properties": {
          "iri": {
            "type": "string",
            "format": "iri"
          },
          "typ": {
            "oneOf": [
              {
                "const": "Dobrovolný svazek obcí"
              },
              {
                "type": "array",
                "contains": {
                  "const": "Dobrovolný svazek obcí"
                },
                "items": {
                  "type": "string"
                }
              }
            ]
          },
          "ičo": {
            "title": "identifikační číslo osoby",
            "description": "Identifikační číslo osoby je jednoznačné číslo, jehož přidělení je spojeno s registrací nebo evidencí osoby.",
            "type": "string",
            "pattern": "[0-9]{8}"
          },
          "název": {
            "title": "Má název orgánu veřejné moci",
            "description": "Pojmenovává orgán veřejné moci názvem, který je oficiálním názvem orgánu veřejné moci. Název je referenčním údajem převzatým z registru obyvatel nebo z registru osob.",
            "type": "object",
            "additionalProperties": {
              "title": "Hodnota v jiném jazyce",
              "type": "string"
            },
            "properties": {
              "cs": {
                "title": "Hodnota v českém jazyce",
                "type": "string"
              },
              "en": {
                "title": "Hodnota v anglickém jazyce",
                "type": "string"
              }
            }
          },
          "idds": {
            "title": "Má identifikátor datové schránky",
            "description": "Jednoznačný identifikátor datové schránky.",
            "type": "string"
          },
          "web": {
            "title": "webová stránka svazku obcí",
            "description": "webová stránka dobrovolného svazku obcí ve formátu URL ",
            "type": "string",
            "format": "iri"
          },
          "datum_vzniku": {
            "title": "Má datum zahájení výkonu působnosti orgánu veřejné moci",
            "description": "Datum, od kterého orgán veřejné moci vykonává působnost",
            "type": "string",
            "format": "date"
          },
          "datum_zániku": {
            "title": "Má datum ukončení výkonu působnosti orgánu veřejné moci",
            "description": "Datum, do kterého orgán veřejné moci vykonává působnost",
            "type": "string",
            "format": "date"
          },
          "datum_zrušení": {
            "title": "datum zrušení svazku obcí",
