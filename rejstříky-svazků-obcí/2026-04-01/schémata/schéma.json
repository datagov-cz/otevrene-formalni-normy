                  "type": "object",
                  "additionalProperties": {
                    "title": "Hodnota v jiném jazyce",
                    "type": "string"
                  },
                  "required": [
                    "cs"
                  ],
                  "properties": {
                    "cs": {
                      "title": "Hodnota v českém jazyce",
