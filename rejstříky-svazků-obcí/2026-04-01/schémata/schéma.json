                        "title": "je vykonávána fyzickou osobou",
                        "type": "array",
                        "items": {
                          "title": "Fyzická osoba",
                          "description": "Každý člověk má vrozená, již samotným rozumem a citem poznatelná přirozená práva, a tudíž se považuje za osobu. Zákon stanoví jen meze uplatňování přirozených práv člověka a způsob jejich ochrany. Člověk má právní osobnost od narození až do smrti.",
                          "type": "object",
                          "required": [
                            "jméno",
                            "příjmení"
                          ],
                          "properties": {
                            "jméno": {
                              "title": "jméno fyzické osoby",
                              "description": "Jméno člověka je jeho osobní jméno a příjmení, popřípadě jeho další jména a rodné příjmení, která mu podle zákona náležejí. Každý člověk má právo užívat své jméno v právním styku, stejně jako právo na ochranu svého jména a na úctu k němu.",
                              "type": "string"
                            },
                            "příjmení": {
                              "title": "příjmení fyzické osoby",
                              "type": "string"
                            },
                            "má_bydliště_fyzické_osoby": {
                              "title": "má bydliště fyzické osoby",
                              "description": "Člověk má bydliště v místě, kde se zdržuje s úmyslem žít tam s výhradou změny okolností trvale; takový úmysl může vyplývat z jeho prohlášení nebo z okolností případu. Uvádí-li člověk jako své bydliště jiné místo než své skutečné bydliště, může se každý dovolat i jeho skutečného bydliště. Proti tomu, kdo se v dobré víře dovolá uvedeného místa, nemůže člověk namítat, že má své skutečné bydliště v jiném místě.",
                              "type": "object",
                              "anyOf": [
                                {
                                  "type": "object"
                                },
                                {
                                  "type": "object",
                                  "oneOf": [
                                    {
                                      "type": "object",
                                      "required": [
                                        "adresa_neevidovaná_v_rúian"
                                      ],
                                      "properties": {
                                        "adresa_neevidovaná_v_rúian": {
                                          "title": "Řetězec",
                                          "type": "string"
                                        }
                                      }
                                    },
                                    {
                                      "type": "object",
                                      "required": [
                                        "zahraniční_adresa"
                                      ],
                                      "properties": {
                                        "zahraniční_adresa": {
                                          "title": "lokalizační popis",
                                          "type": "string"
                                        }
                                      }
                                    },
                                    {
                                      "type": "object",
                                      "required": [
                                        "adresní_místo"
                                      ],
                                      "properties": {
                                        "adresní_místo": {
                                          "title": "má kód adresního místa",
                                          "type": "string",
                                          "format": "iri",
                                          "pattern": "^https://linked.cuzk.gov.cz/resource/ruian/adresni-misto/[0-9]+$"
                                        }
                                      }
                                    }
                                  ]
                                }
                              ]
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
