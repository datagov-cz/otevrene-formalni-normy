      "oneOf": [
        {
          "const": "https://ofn.gov.cz/rejstříky-svazků-obcí/2026-04-01/kontexty/kontext.jsonld"
        },
        {
          "type": "array",
          "contains": {
            "const": "https://ofn.gov.cz/rejstříky-svazků-obcí/2026-04-01/kontexty/kontext.jsonld"
          },
          "items": {
            "type": "string",
            "format": "iri"
          }
        }
      ]
    },
    "iri": {
      "type": "string",
      "format": "iri"
    },
    "typ": {
      "oneOf": [
        {
          "const": "Rejstřík svazků obcí"
